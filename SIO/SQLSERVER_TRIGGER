---- Creation Trigger  DeleteLogsNews
USE [AutomateIA]
GO
/****** Object:  Trigger [dbo].[DeleteLogsNews]    Script Date: 20/03/2026 11:18:35 ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE TRIGGER [dbo].[DeleteLogsNews]
ON [dbo].[News]
INSTEAD OF DELETE
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @IDNews INT;
    DECLARE @NewsTitle VARCHAR(200);

    SELECT @IDNews = new_id FROM DELETED;

	SELECT @NewsTitle = new_title FROM DELETED ;

	DECLARE @NewsArticle VARCHAR(200);
	SELECT @NewsArticle = new_article FROM DELETED;

	DECLARE @NewsDate  DATETIME;
	SELECT @NewsDate = new_date FROM DELETED;
  
	DECLARE @NewsLastBy  VARCHAR(200);
	SELECT @NewsLastBy = new_lastBy FROM INSERTED;

	DECLARE @OLDLastBy  VARCHAR(200);
	SELECT @OLDLastBy = new_lastBy FROM DELETED;

	IF @OLDLastBy LIKE 'JFE'
	INSERT INTO [dbo].[LogsNews]
           ([logn_idnews]
           ,[logn_title]
           ,[logn_article]
           ,[logn_date]
           ,[logn_lastby]
           ,[logn_typeev])
     VALUES
           (@IDNews
           ,@NewsTitle
           ,@NewsArticle
           ,@NewsDate
           ,@NewsLastBy
           ,'SUPRESSION');

END

